[gd_scene format=3 uid="uid://c6ycven2ggsh2"]

[ext_resource type="Texture2D" uid="uid://bv38roadvpmte" path="res://Sprites/icon.svg" id="1_irgen"]

[sub_resource type="GDScript" id="GDScript_irgen"]
resource_name = "res://Inimigos/perseguidor.gd"
script/source = "extends CharacterBody2D

const SPEED := 80

@export var player: Node2D
@export var damage_amount: int = 1
@export var damage_cooldown: float = 0.8

@onready var nav_agent := $NavigationAgent2D as NavigationAgent2D
@onready var damage_area := $DamageArea as Area2D

var can_damage := true


func _ready() -> void:
	makepath()

	damage_area.body_entered.connect(_on_damage_area_body_entered)


func _physics_process(_delta: float) -> void:
	if player == null:
		return

	var next_position := nav_agent.get_next_path_position()
	var direction := global_position.direction_to(next_position)

	velocity = direction * SPEED
	move_and_slide()


func makepath() -> void:
	if player != null:
		nav_agent.target_position = player.global_position


func _on_timer_timeout() -> void:
	makepath()


func _on_damage_area_body_entered(body: Node2D) -> void:
	if not can_damage:
		return

	if body.is_in_group(\"Player\"):
		if body.has_method(\"take_damage\"):
			body.take_damage(damage_amount)
			can_damage = false
			await get_tree().create_timer(damage_cooldown).timeout
			can_damage = true
"

